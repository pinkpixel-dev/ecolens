{
  "name": "ecolens",
  "version": "0.1.0",
  "private": true,
  "description": "EcoLens is an AI-powered responsible consumption scanner for hackathon rapid prototyping.",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx --ignore-pattern .next --ignore-pattern .open-next",
    "typecheck": "tsc --noEmit",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "keywords": [
    "sustainability",
    "gemini",
    "nextjs",
    "hackathon"
  ],
  "author": "Pink Pixel",
  "license": "Apache-2.0",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/lib-storage": "^3.1019.0",
    "@google/genai": "^1.31.0",
    "@opennextjs/cloudflare": "^1.18.0",
    "next": "^16.2.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.37.0",
    "eslint-config-next": "^16.0.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.78.0"
  }
}
